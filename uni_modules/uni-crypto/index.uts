	// 工具类：包含所有加密相关的工具函数
	class CryptoUtils {
		// 字符串转 hex
		static stringToHex(str: string): string {
			const encoder = new TextEncoder()
			const bytes = encoder.encode(str)
			let hex = ''
			for (let i = 0; i < bytes.length; i++) {
				const hexStr = bytes[i].toString(16)
				hex += hexStr.length == 1 ? '0' + hexStr : hexStr
			}
			return hex
		}

		// hex 转字符串
		static hexToString(hex: string): string {
			const bytes = new Uint8Array(hex.length / 2)
			for (let i = 0; i < hex.length; i += 2) {
				bytes[i / 2] = parseInt(hex.substring(i, i + 2), 16)
			}
			// 使用 TextDecoder 正确处理 UTF-8 多字节字符
			const decoder = new TextDecoder()
			return decoder.decode(bytes)
		}

		// ArrayBuffer 转 hex
		static arrayBufferToHex(buffer: ArrayBuffer): string {
			const bytes = new Uint8Array(buffer)
			let hex = ''
			for (let i = 0; i < bytes.length; i++) {
				const hexStr = bytes[i].toString(16)
				hex += hexStr.length == 1 ? '0' + hexStr : hexStr
			}
			return hex
		}

		// PKCS7 Padding (hex 格式)
		// blockSize: 块大小（字节数），例如 16
		static addPKCS7Padding(hexData: string, blockSize: number): string {
			const dataLength = hexData.length / 2  // hex 字符串长度除以 2 = 字节数
			const paddingLength = blockSize - (dataLength % blockSize)

			// 将 padding 值转为两位 hex 字符串
			const paddingHex = paddingLength.toString(16).padStart(2, '0')

			// 添加 paddingLength 个 paddingHex
			let result = hexData
			for (let i = 0; i < paddingLength; i++) {
				result += paddingHex
			}

			return result
		}

		// 移除 PKCS7 Padding (hex 格式)
		static removePKCS7Padding(hexData: string): string {
			if (hexData.length < 2) {
				return hexData
			}

			// 读取最后一个字节（最后两个 hex 字符）
			const lastByte = parseInt(hexData.substring(hexData.length - 2), 16)

			// 验证 padding 是否有效
			if (lastByte == 0 || lastByte > 16) {
				return hexData
			}

			// 验证所有 padding 字节是否都等于 paddingLength
			const paddingStartPos = hexData.length - (lastByte * 2)
			for (let i = paddingStartPos; i < hexData.length; i += 2) {
				const byte = parseInt(hexData.substring(i, i + 2), 16)
				if (byte != lastByte) {
					return hexData  // padding 无效，返回原始数据
				}
			}

			// 移除 padding
			return hexData.substring(0, paddingStartPos)
		}

		// hex 转 ArrayBuffer
		static hexToArrayBuffer(hex: string): ArrayBuffer {
			const bytes = new Uint8Array(hex.length / 2)
			for (let i = 0; i < hex.length; i += 2) {
				bytes[i / 2] = parseInt(hex.substring(i, i + 2), 16)
			}
			return bytes.buffer as ArrayBuffer
		}
	}

	// CryptoKey 实现类 - 用于 Android 平台的类型兼容
	export class CryptoKeyImpl {
		type: string
		extractable: boolean
		algorithm: AlgorithmParams
		usages: string[]
		_keyData?: string

		constructor(type: string, extractable: boolean, algorithm: AlgorithmParams, usages: string[], keyData: string) {
			this.type = type
			this.extractable = extractable
			this.algorithm = algorithm
			this.usages = usages
			this._keyData = keyData
		}
	}

	// SubtleCrypto 实现类
	class SubtleCryptoImpl {
		async digest(algorithm: string, data: ArrayBuffer | Uint8Array): Promise<ArrayBuffer> {
			const dataArray = data instanceof ArrayBuffer ? new Uint8Array(data) : data
			const dataHex = CryptoUtils.arrayBufferToHex(dataArray.buffer as ArrayBuffer)

			try {
				let resultHex: string

				if (algorithm == 'SHA-256') {
					const result = sha256Hash(dataHex)
					if (result.errorMsg.length > 0) {
						throw new Error(result.errorMsg)
					}
					resultHex = result.result
				} else if (algorithm == 'MD5') {
					const result = md5Hash(dataHex)
					if (result.errorMsg.length > 0) {
						throw new Error(result.errorMsg)
					}
					resultHex = result.result
				} else {
					throw new Error(`不支持的算法: ${algorithm}`)
				}

				if (resultHex.length == 0) {
					throw new Error(`digest(${algorithm}) 返回空结果`)
				}

				return CryptoUtils.hexToArrayBuffer(resultHex)
			} catch (e) {
				console.error(`[uni-crypto APP] digest(${algorithm}) 错误:`, e)
				throw e
			}
		}

		async importKey(
			format: string,
			keyData: KeyData,
			algorithm: AlgorithmParams,
			extractable: boolean,
			keyUsages: string[]
		): Promise<CryptoKey> {
			// 将密钥数据转换为 hex 字符串存储
			let keyHex: string = ''
			if (keyData instanceof ArrayBuffer) {
				keyHex = CryptoUtils.arrayBufferToHex(keyData)
			} else if (keyData instanceof Uint8Array) {
				keyHex = CryptoUtils.arrayBufferToHex(keyData.buffer as ArrayBuffer)
			} else if (typeof keyData == 'string') {
				// 如果是字符串，假设已经是 hex 格式
				keyHex = keyData
			}

			return new CryptoKeyImpl('secret', extractable, algorithm, keyUsages, keyHex)
		}

		async exportKey(format: string, key: CryptoKeyImpl): Promise<ExportKeyResult> {
			// 检查密钥是否可导出
			if (!key.extractable) {
				throw new Error('Key is not extractable')
			}

			// 只支持 'raw' 格式导出
			if (format != 'raw') {
				throw new Error(`Unsupported export format: ${format}`)
			}

			// 从存储的 _keyData 中提取密钥
			const keyHex = key._keyData ?? ''
			if (keyHex.length == 0) {
				throw new Error('No key data stored in CryptoKey')
			}

			// 返回 ArrayBuffer
			return CryptoUtils.hexToArrayBuffer(keyHex)
		}

		async generateKey(
			algorithm: AlgorithmParams,
			extractable: boolean,
			keyUsages: string[]
		): Promise<CryptoKey | CryptoKeyPair> {
			// 只支持 AES 密钥生成
			const algoName = algorithm.name ?? ''

			if (algoName == 'AES-GCM' || algoName == 'AES-CBC') {
				// 从算法参数中获取密钥长度，默认 256 位
				const length = algorithm.length ?? 256

				// 验证密钥长度
				if (length != 128 && length != 192 && length != 256) {
					throw new Error(`Invalid AES key length: ${length}. Must be 128, 192, or 256`)
				}

				// 生成随机密钥字节
				const keyBytes = length / 8
				const keyArray = new Uint8Array(keyBytes)
				RandomGenerator.getRandomValues(keyArray)

				// 转换为 hex 字符串
				const keyHex = CryptoUtils.arrayBufferToHex(keyArray.buffer as ArrayBuffer)

				// 创建 CryptoKey 对象
				return new CryptoKeyImpl('secret', extractable, algorithm, keyUsages, keyHex)
			} else {
				throw new Error(`Unsupported algorithm for key generation: ${algoName}`)
			}
		}

		async encrypt(
			algorithm: AlgorithmParams,
			key: CryptoKeyImpl,
			data: ArrayBuffer | Uint8Array
		): Promise<ArrayBuffer> {
			const dataArray = data instanceof ArrayBuffer ? new Uint8Array(data) : data
			const dataHex = CryptoUtils.arrayBufferToHex(dataArray.buffer as ArrayBuffer)

			try {
				// 获取算法名称
				let algoName: string = ''
				if (algorithm.name != null) {
					algoName = algorithm.name
				} else if (key.algorithm.name != null) {
					algoName = key.algorithm.name
				}

				if (algoName == 'AES-GCM') {
					// 从 CryptoKey 中提取密钥数据
				const keyHex = key._keyData ?? ''
				if (keyHex.length == 0) {
					throw new Error('No key data found in CryptoKey')
				}
					let iv = '000000000000000000000000'
					let aad = ''
					if (algorithm.iv != null) {
						const ivData = algorithm.iv instanceof ArrayBuffer ? new Uint8Array(algorithm.iv) : algorithm.iv
						iv = CryptoUtils.arrayBufferToHex(ivData.buffer as ArrayBuffer)
					}
					if (algorithm.additionalData != null) {
						const aadData = algorithm.additionalData instanceof ArrayBuffer ? new Uint8Array(algorithm.additionalData) : algorithm.additionalData
						aad = CryptoUtils.arrayBufferToHex(aadData.buffer as ArrayBuffer)
					}

					const result = aesGcmEncryptNative(keyHex, iv, aad, dataHex)
					if (result.errorMsg.length > 0) {
						throw new Error(result.errorMsg)
					}

					return CryptoUtils.hexToArrayBuffer(result.encrypted)
				} else if (algoName == 'AES-CBC') {
					// 从 CryptoKey 中提取密钥数据
					const keyHex = key._keyData ?? ''
					if (keyHex.length == 0) {
						throw new Error('No key data found in CryptoKey')
					}
					let iv = '00000000000000000000000000000000'
					if (algorithm.iv != null) {
						const ivData = algorithm.iv instanceof ArrayBuffer ? new Uint8Array(algorithm.iv) : algorithm.iv
						iv = CryptoUtils.arrayBufferToHex(ivData.buffer as ArrayBuffer)
					}

					const result = aesCbcEncryptNative(keyHex, iv, dataHex)
					if (result.errorMsg.length > 0) {
						throw new Error(result.errorMsg)
					}

					return CryptoUtils.hexToArrayBuffer(result.encrypted)
				} else {
					throw new Error(`不支持的加密算法: ${algoName}`)
				}
			} catch (e) {
				console.error('[uni-crypto APP] encrypt 错误:', e)
				throw e
			}
		}

		async decrypt(
			algorithm: AlgorithmParams,
			key: CryptoKeyImpl,
			data: ArrayBuffer | Uint8Array
		): Promise<ArrayBuffer> {
			const dataArray = data instanceof ArrayBuffer ? new Uint8Array(data) : data
			const dataHex = CryptoUtils.arrayBufferToHex(dataArray.buffer as ArrayBuffer)

			try {
				// 获取算法名称
				let algoName: string = ''
				if (algorithm.name != null) {
					algoName = algorithm.name
				} else if (key.algorithm.name != null) {
					algoName = key.algorithm.name
				}

				if (algoName == 'AES-GCM') {
					// 从 CryptoKey 中提取密钥数据
				const keyHex = key._keyData ?? ''
				if (keyHex.length == 0) {
					throw new Error('No key data found in CryptoKey')
				}
					let iv = '000000000000000000000000'
					let aad = ''
					if (algorithm.iv != null) {
						const ivData = algorithm.iv instanceof ArrayBuffer ? new Uint8Array(algorithm.iv) : algorithm.iv
						iv = CryptoUtils.arrayBufferToHex(ivData.buffer as ArrayBuffer)
					}
					if (algorithm.additionalData != null) {
						const aadData = algorithm.additionalData instanceof ArrayBuffer ? new Uint8Array(algorithm.additionalData) : algorithm.additionalData
						aad = CryptoUtils.arrayBufferToHex(aadData.buffer as ArrayBuffer)
					}

					const result = aesGcmDecryptNative(keyHex, iv, aad, dataHex)
					if (result.errorMsg.length > 0) {
						throw new Error(result.errorMsg)
					}

					return CryptoUtils.hexToArrayBuffer(result.decrypted)
				} else if (algoName == 'AES-CBC') {
					// 从 CryptoKey 中提取密钥数据
				const keyHex = key._keyData ?? ''
				if (keyHex.length == 0) {
					throw new Error('No key data found in CryptoKey')
				}
					let iv = '00000000000000000000000000000000'
					if (algorithm.iv != null) {
						const ivData = algorithm.iv instanceof ArrayBuffer ? new Uint8Array(algorithm.iv) : algorithm.iv
						iv = CryptoUtils.arrayBufferToHex(ivData.buffer as ArrayBuffer)
					}

					const result = aesCbcDecryptNative(keyHex, iv, dataHex)
					if (result.errorMsg.length > 0) {
						throw new Error(result.errorMsg)
					}

					return CryptoUtils.hexToArrayBuffer(result.decrypted)
				} else {
					throw new Error(`不支持的解密算法: ${algoName}`)
				}
			} catch (e) {
				console.error('[uni-crypto APP] decrypt 错误:', e)
				throw e
			}
		}

