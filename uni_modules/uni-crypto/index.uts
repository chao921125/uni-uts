	/**
	 * 从 DER 编码的私钥中提取纯 hex 格式私钥
	 * DER 格式: 30 77 02 01 01 04 20 [32字节私钥] ...
	 * 查找标记 "0420"，然后提取后面的64个字符（32字节）
	 */
	function extractPrivateKeyFromDER(derHex: string): string {
		const marker = '0420'
		const index = derHex.indexOf(marker)
		if (index >= 0) {
			const start = index + marker.length
			return derHex.substring(start, start + 64)
		}
		// 如果找不到标记，返回原始数据（可能已经是纯hex格式）
		return derHex
	}

	/**
	 * 从 DER 编码的公钥中提取纯 hex 格式公钥
	 * DER 格式: 30 59 30 13 ... 03 42 00 04 [64字节公钥x+y]
	 * 查找标记 "0004"，然后提取后面的130个字符（包含"04"前缀）
	 */
	function extractPublicKeyFromDER(derHex: string): string {
		const marker = '0004'
		const index = derHex.indexOf(marker)
		if (index >= 0) {
			const start = index + 2  // 跳过 '00'，保留 '04' 前缀
			return derHex.substring(start, start + 130)
		}
		// 如果找不到标记，返回原始数据（可能已经是纯hex格式）
		return derHex
	}

	// 密钥缓存：用于保存纯 hex 到 DER 的映射
	const keyCache = new Map<string, string>()

	/**
	 * 将纯 hex 格式公钥转换为 DER 格式
	 * 如果输入已经是 DER 格式（长度>130），直接返回
	 * 如果是纯 hex 格式（130字符），构造 DER 格式
	 */
	function convertPublicKeyToDER(hexKey: string): string {
		// 检查缓存
		const cached = keyCache.get(hexKey)
		if (cached != null) {
			return cached
		}

		// 如果已经是 DER 格式（长度大于130），直接返回
		if (hexKey.length > 130) {
			return hexKey
		}

		// 如果是130字符的纯hex，构造标准DER格式
		// DER 格式: 30 59 30 13 06 07 2a 86 48 ce 3d 02 01 06 08 2a 81 1c cf 55 01 82 2d 03 42 00 [公钥]
		if (hexKey.length == 130) {
			const derPrefix = '3059301306072a8648ce3d020106082a811ccf5501822d034200'
			return derPrefix + hexKey
		}

		// 其他情况直接返回原值
		return hexKey
	}

	/**
	 * 将纯 hex 格式私钥转换为 DER 格式
	 * 如果输入已经是 DER 格式（长度>64），直接返回
	 * 如果是纯 hex 格式（64字符），从缓存中查找完整DER
	 */
	function convertPrivateKeyToDER(hexKey: string): string {
		// 去掉可能的前导 00
		let normalizedKey = hexKey
		if (hexKey.length == 66 && hexKey.startsWith('00')) {
			normalizedKey = hexKey.substring(2)
		}

		// 检查缓存
		const cached = keyCache.get(normalizedKey)
		if (cached != null) {
			return cached
		}

		// 如果已经是 DER 格式（长度大于64），直接返回
		if (normalizedKey.length > 64) {
			return normalizedKey
		}

		// 如果是64字符的纯hex但没有缓存，无法构造完整DER（缺少公钥信息）
		// 返回原值，让底层尝试处理
		return normalizedKey
	}

	// SM2 实现类
	class SM2Impl {
		generateKeyPairHex(): SM2KeyPairHex {
			try {
				const keyPairJson = sm2KeyGenerateNative()
				if (keyPairJson.length == 0) {
					throw new Error('SM2 密钥对生成返回空结果')
				}

			// 解析 JSON 格式的密钥对
			// 注意：UTS 类型系统严格，在 Android 平台 JSON.parse 返回 UTSJSONObject 无法直接转换
			// 使用手动字符串解析方式避免类型转换错误
			try {
				// 手动解析 JSON 字符串，避免使用 JSON.parse 的类型转换问题
				const privateKeyMatch = keyPairJson.match(/"privateKey"\s*:\s*"([^"]+)"/)
				const publicKeyMatch = keyPairJson.match(/"publicKey"\s*:\s*"([^"]+)"/)

				const privateKeyDER: string = (privateKeyMatch != null && privateKeyMatch.length > 1) ? (privateKeyMatch[1] ?? '') : ''
				const publicKeyDER: string = (publicKeyMatch != null && publicKeyMatch.length > 1) ? (publicKeyMatch[1] ?? '') : ''

				if (privateKeyDER.length == 0 || publicKeyDER.length == 0) {
					console.error('[uni-crypto APP] ❌ SM2 密钥对 JSON 解析失败: 无法提取密钥')
					throw new Error('SM2 密钥对 JSON 解析失败: 无法提取密钥')
				}

				// 从 DER 格式提取纯 hex 格式密钥（与 Web 端保持一致）
				const privateKey = extractPrivateKeyFromDER(privateKeyDER)
				const publicKey = extractPublicKeyFromDER(publicKeyDER)

				// 缓存纯 hex 到 DER 的映射，用于后续加密/解密操作
				if (privateKey.length > 0 && privateKeyDER.length > 0) {
					keyCache.set(privateKey, privateKeyDER)
				}
				if (publicKey.length > 0 && publicKeyDER.length > 0) {
					keyCache.set(publicKey, publicKeyDER)
				}

				console.log(`[uni-crypto APP] ✅ SM2 密钥生成成功 - 公钥: ${publicKey.length}字符, 私钥: ${privateKey.length}字符`)
				const result: SM2KeyPairHex = {
					privateKey: privateKey,
					publicKey: publicKey
				}
				return result
			} catch (parseError) {
				console.error('[uni-crypto APP] SM2 密钥对 JSON 解析失败:', parseError)
				throw new Error('SM2 密钥对 JSON 解析失败')
			}
			} catch (e) {
				console.error('[uni-crypto APP] sm2.generateKeyPairHex 错误:', e)
				throw e
			}
		}

		doEncrypt(msg: string, publicKey: string, cipherMode: number | null): string {
			try {
				// 注意：当前 C 实现固定使用 C1C3C2 模式（mode=1），cipherMode 参数保留以保持与 sm-crypto API 一致
				// 将纯 hex 公钥转换为 DER 格式（底层 C 函数需要 DER 格式）
				const derPublicKey = convertPublicKeyToDER(publicKey)

				// 将消息转换为 hex
				const msgHex = CryptoUtils.stringToHex(msg)

				const encrypted = sm2EncryptNative(derPublicKey, msgHex)
				if (encrypted.length == 0) {
					console.error('[uni-crypto APP] ❌ SM2 加密失败: 返回空结果')
					throw new Error('SM2 加密返回空结果')
				}

				console.log(`[uni-crypto APP] ✅ SM2 加密成功 - 密文长度: ${encrypted.length}字符`)
				return encrypted
			} catch (e) {
				console.error('[uni-crypto APP] ❌ SM2 加密错误:', e)
				throw e
			}
		}

		doDecrypt(cipherText: string, privateKey: string, cipherMode: number | null): string {
			try {
				// 注意：当前 C 实现固定使用 C1C3C2 模式（mode=1），cipherMode 参数保留以保持与 sm-crypto API 一致
				// 将纯 hex 私钥转换为 DER 格式（底层 C 函数需要 DER 格式）
				const derPrivateKey = convertPrivateKeyToDER(privateKey)

				const plaintextHex = sm2DecryptNative(derPrivateKey, cipherText)
				if (plaintextHex.length == 0) {
					throw new Error('SM2 解密返回空结果')
				}

				// 将 hex 转换回字符串
				return CryptoUtils.hexToString(plaintextHex)
			} catch (e) {
				console.error('[uni-crypto APP] sm2.doDecrypt 错误:', e)
				throw e
			}
		}

		doSignature(msg: string, privateKey: string, ...args: (SM2Options | null)[]): string {
			try {
				const options = args.length > 0 ? args[0] : null

				// 将纯 hex 私钥转换为 DER 格式（底层 C 函数需要 DER 格式）
				const derPrivateKey = convertPrivateKeyToDER(privateKey)

				// 将消息转换为 hex
				let msgHex: string
				if (options != null && options.inputEncoding == 'hex') {
					msgHex = msg
				} else {
					msgHex = CryptoUtils.stringToHex(msg)
				}

				const signature = sm2SignNative(derPrivateKey, msgHex)
				if (signature.length == 0) {
					throw new Error('SM2 签名返回空结果')
				}

				return signature
			} catch (e) {
				console.error('[uni-crypto APP] sm2.doSignature 错误:', e)
				throw e
			}
		}

		doVerifySignature(msg: string, signHex: string, publicKey: string, ...args: (SM2Options | null)[]): boolean {
			try {
				const options = args.length > 0 ? args[0] : null

				// 将纯 hex 公钥转换为 DER 格式（底层 C 函数需要 DER 格式）
				const derPublicKey = convertPublicKeyToDER(publicKey)

				// 将消息转换为 hex
				let msgHex: string
				if (options != null && options.inputEncoding == 'hex') {
					msgHex = msg
				} else {
					msgHex = CryptoUtils.stringToHex(msg)
				}

				return sm2VerifyNative(derPublicKey, msgHex, signHex)
			} catch (e) {
				console.error('[uni-crypto APP] sm2.doVerifySignature 错误:', e)
				return false
			}
		}
	}

	// SM3 实现类
	class SM3Impl {
		hash(msg: string, ...args: (SM3Options | null)[]): string {
			try {
				const options = args.length > 0 ? args[0] : null
				let msgHex: string
				if (options != null && options.inputEncoding == 'hex') {
					msgHex = msg
				} else {
					msgHex = CryptoUtils.stringToHex(msg)
				}

				const result = sm3Hash(msgHex)
				if (result.errorMsg.length > 0) {
					throw new Error(result.errorMsg)
				}

				return result.result
			} catch (e) {
				console.error('[uni-crypto APP] sm3 错误:', e)
				throw e
			}
		}

		hmac(key: string, data: string): string {
			try {
				// 将字符串转换为 hex
				const keyHex = CryptoUtils.stringToHex(key)
				const dataHex = CryptoUtils.stringToHex(data)

				const result = sm3Hmac(keyHex, dataHex)
				if (result.errorMsg.length > 0) {
					throw new Error(result.errorMsg)
				}
				return result.mac
			} catch (e) {
				console.error('[uni-crypto APP] sm3Hmac 错误:', e)
				throw e
			}
		}
	}

	// SM4 实现类
	class SM4Impl {
		encrypt(msg: string, key: string, ...args: (SM4EncryptOptions | null)[]): string {
			try {
				const options = args.length > 0 ? args[0] : null
				let msgHex: string
				if (options != null && options.inputEncoding == 'hex') {
					msgHex = msg
				} else {
					msgHex = CryptoUtils.stringToHex(msg)
				}

				console.log('[uni-crypto APP] sm4Encrypt 原始hex长度:', msgHex.length, 'hex:', msgHex)

				// SM4 ECB 模式自动添加 PKCS7 padding
				if (msgHex.length % 32 != 0) {
					msgHex = CryptoUtils.addPKCS7Padding(msgHex, 16)
					console.log('[uni-crypto APP] sm4Encrypt 添加padding后长度:', msgHex.length, 'hex:', msgHex)
				}

				// C 库的 ECB 模式只支持单块加密，需要手动处理多块
				// 每块 16 字节 = 32 hex 字符
				let encryptedHex = ''
				for (let i = 0; i < msgHex.length; i += 32) {
					const block = msgHex.substring(i, i + 32)
					console.log('[uni-crypto APP] sm4Encrypt 处理块:', i / 32, 'hex:', block)
					const result = sm4EncryptNative(key, block)
					if (result.errorMsg.length > 0) {
						throw new Error(result.errorMsg)
					}
					encryptedHex += result.encrypted
				}

				if (options != null && options.outputEncoding == 'base64') {
					// 需要实现 hex 转 base64
					return encryptedHex // 临时返回 hex
				}
				return encryptedHex
			} catch (e) {
				console.error('[uni-crypto APP] sm4.encrypt 错误:', e)
				throw e
			}
		}

		decrypt(cipherText: string, key: string, ...args: (SM4DecryptOptions | null)[]): string {
			try {
				const options = args.length > 0 ? args[0] : null
				let cipherHex: string = cipherText
				if (options != null && options.inputEncoding == 'base64') {
					cipherHex = cipherText // 临时
				}

				// SM4 ECB 模式要求数据长度必须是 16 字节（32 字符 hex）的倍数
				if (cipherHex.length % 32 != 0) {
					throw new Error('SM4 ECB 模式要求密文长度必须是 16 字节的倍数')
				}

				// C 库的 ECB 模式只支持单块解密，需要手动处理多块
				let decryptedHex = ''
				for (let i = 0; i < cipherHex.length; i += 32) {
					const block = cipherHex.substring(i, i + 32)
					console.log('[uni-crypto APP] sm4Decrypt 处理块:', i / 32, 'hex:', block)
					const result = sm4DecryptNative(key, block)
					if (result.errorMsg.length > 0) {
						throw new Error(result.errorMsg)
					}
					decryptedHex += result.decrypted
				}

				// 移除 PKCS7 padding
				const unpaddedHex = CryptoUtils.removePKCS7Padding(decryptedHex)

				if (options != null && options.outputEncoding == 'text') {
					return CryptoUtils.hexToString(unpaddedHex)
				}
				return unpaddedHex
			} catch (e) {
				console.error('[uni-crypto APP] sm4.decrypt 错误:', e)
				throw e
			}
		}

		encryptCBC(msg: string, key: string, iv: string, ...args: (SM4EncryptOptions | null)[]): string {
			try {
				const options = args.length > 0 ? args[0] : null
				let msgHex: string
				if (options != null && options.inputEncoding == 'hex') {
					msgHex = msg
				} else {
					msgHex = CryptoUtils.stringToHex(msg)
				}

				const result = sm4CbcEncryptNative(key, iv, msgHex)
				if (result.errorMsg.length > 0) {
					throw new Error(result.errorMsg)
				}

				if (options != null && options.outputEncoding == 'base64') {
					return result.encrypted // 临时
				}
				return result.encrypted
			} catch (e) {
				console.error('[uni-crypto APP] sm4.encryptCBC 错误:', e)
				throw e
			}
		}

		decryptCBC(cipherText: string, key: string, iv: string, ...args: (SM4DecryptOptions | null)[]): string {
			try {
				const options = args.length > 0 ? args[0] : null
				let cipherHex: string = cipherText
				if (options != null && options.inputEncoding == 'base64') {
					cipherHex = cipherText // 临时
				}

				const result = sm4CbcDecryptNative(key, iv, cipherHex)
				if (result.errorMsg.length > 0) {
					throw new Error(result.errorMsg)
				}

				if (options != null && options.outputEncoding == 'text') {
					return CryptoUtils.hexToString(result.decrypted)
				}
				return result.decrypted
			} catch (e) {
				console.error('[uni-crypto APP] sm4.decryptCBC 错误:', e)
				throw e
			}
		}
	}

	// 随机数生成器类
	class RandomGenerator {
		static getRandomValues(array: GetRandomOption): GetRandomOption {
			// APP 平台可以使用系统提供的随机数生成器
			// iOS: 应该调用 SecRandomCopyBytes
			// Android: 应该调用 SecureRandom
			// 这里简化实现，实际应该调用平台特定的随机数生成器
			if (array instanceof Uint8Array) {
				for (let i = 0; i < (array as Uint8Array).length; i++) {
					(array as Uint8Array)[i] = Math.floor(Math.random() * 256)
				}
			} else if (array instanceof Int8Array) {
				for (let i = 0; i < (array as Int8Array).length; i++) {
					(array as Int8Array)[i] = Math.floor(Math.random() * 256)
				}
			} else if (array instanceof Uint16Array) {
				for (let i = 0; i < (array as Uint16Array).length; i++) {
					(array as Uint16Array)[i] = Math.floor(Math.random() * 65536)
				}
			} else if (array instanceof Int16Array) {
				for (let i = 0; i < (array as Int16Array).length; i++) {
					(array as Int16Array)[i] = Math.floor(Math.random() * 65536)
				}
			} else if (array instanceof Uint32Array) {
				for (let i = 0; i < (array as Uint32Array).length; i++) {
					(array as Uint32Array)[i] = Math.floor(Math.random() * 4294967296)
				}
			} else if (array instanceof Int32Array) {
				for (let i = 0; i < (array as Int32Array).length; i++) {
					(array as Int32Array)[i] = Math.floor(Math.random() * 4294967296)
				}
			}
			return array
		}
	}

	// AES 辅助类
	class AESHelper {
		static encrypt(key: string, data: string): string {
			try {
				// 将数据转换为 hex，密钥已经是 hex 格式
				let dataHex = CryptoUtils.stringToHex(data)

				console.log('[uni-crypto APP] aesEncrypt 原始hex长度:', dataHex.length, 'hex:', dataHex)

				// AES ECB 模式自动添加 PKCS7 padding (16 字节块)
				if (dataHex.length % 32 != 0) {
					dataHex = CryptoUtils.addPKCS7Padding(dataHex, 16)
					console.log('[uni-crypto APP] aesEncrypt 添加padding后长度:', dataHex.length, 'hex:', dataHex)
				}

				// C 库的 ECB 模式只支持单块加密，需要手动处理多块
				let encryptedHex = ''
				for (let i = 0; i < dataHex.length; i += 32) {
					const block = dataHex.substring(i, i + 32)
					console.log('[uni-crypto APP] aesEncrypt 处理块:', i / 32, 'hex:', block)
					const result = aesEncryptNative(key, block)
					if (result.errorMsg.length > 0) {
						throw new Error(result.errorMsg)
					}
					encryptedHex += result.encrypted
				}
				return encryptedHex
			} catch (e) {
				console.error('[uni-crypto APP] aesEncrypt 错误:', e)
				throw e
			}
		}

		static decrypt(key: string, encrypted: string): string {
			try {
				// encrypted 已经是 hex 格式，需要按块处理
				if (encrypted.length % 32 != 0) {
					throw new Error('AES ECB 模式要求密文长度必须是 16 字节的倍数')
				}

				// C 库的 ECB 模式只支持单块解密，需要手动处理多块
				let decryptedHex = ''
				for (let i = 0; i < encrypted.length; i += 32) {
					const block = encrypted.substring(i, i + 32)
					console.log('[uni-crypto APP] aesDecrypt 处理块:', i / 32, 'hex:', block)
					const result = aesDecryptNative(key, block)
					if (result.errorMsg.length > 0) {
						throw new Error(result.errorMsg)
					}
					decryptedHex += result.decrypted
				}

				// 移除 PKCS7 padding
				const unpaddedHex = CryptoUtils.removePKCS7Padding(decryptedHex)

				// 将解密后的 hex 转换为字符串
				return CryptoUtils.hexToString(unpaddedHex)
			} catch (e) {
				console.error('[uni-crypto APP] aesDecrypt 错误:', e)
				throw e
			}
		}
	}

	// 主导出类
	class Crypto {
		subtle: SubtleCryptoImpl
		sm2: SM2Impl
		sm4: SM4Impl
		private sm3Impl: SM3Impl

		constructor() {
			this.subtle = new SubtleCryptoImpl()
			this.sm2 = new SM2Impl()
			this.sm4 = new SM4Impl()
			this.sm3Impl = new SM3Impl()
		}

		sm3(msg: string, ...arg: (SM3Options | null)[]): string {
			const options = arg.length > 0 ? arg[0] : null
			return this.sm3Impl.hash(msg, options)
		}

		sm3Hmac(key: string, data: string): string {
			return this.sm3Impl.hmac(key, data)
		}

		aesEncrypt(key: string, data: string): string {
			return AESHelper.encrypt(key, data)
		}

		aesDecrypt(key: string, encrypted: string): string {
			return AESHelper.decrypt(key, encrypted)
		}

		getRandomValues(array: GetRandomOption): GetRandomOption {
			return RandomGenerator.getRandomValues(array)
		}
	}
	
	const crypto = new Crypto()
	// const hash = crypto.sm3Hmac('testMsg', '123')
	// console.error('crypto.sm3Hmac(testMsg)', hash)

	// 导出 CryptoKeyImpl 作为 CryptoKey 供外部使用
	export type CryptoKey = CryptoKeyImpl

	export default crypto
//#endif
