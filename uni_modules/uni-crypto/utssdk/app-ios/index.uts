export function aesGcmEncrypt(key: string, iv: string, aad: string, data: string): AESGcmEncryptResult {
  try {
    let aadValue: string = ''
    if (aad.length > 0) {
      aadValue = aad
    }
    const encrypted = getBridge().aesGcmEncrypt(withKey = key, iv = iv, aad = aadValue, data = data)
    
    if (encrypted == null) {
      return {
        encrypted: '',
        errorMsg: 'Encrypt result is null'
      }
    }
    
    const encryptedValue: string = encrypted!
    console.log('[uni-crypto iOS] aesGcmEncrypt:', encryptedValue)
    
    return {
      encrypted: encryptedValue,
      errorMsg: ''
    }
  } catch (e) {
    console.error('[uni-crypto iOS] aesGcmEncrypt 错误:', e)
    return {
      encrypted: '',
      errorMsg: `Error: ${e}`
    }
  }
}

export function aesGcmDecrypt(key: string, iv: string, aad: string, encrypted: string): AESGcmDecryptResult {
  try {
    let aadValue: string = ''
    if (aad.length > 0) {
      aadValue = aad
    }
    const decrypted = getBridge().aesGcmDecrypt(withKey = key, iv = iv, aad = aadValue, encrypted = encrypted)
    
    if (decrypted == null) {
      return {
        decrypted: '',
        errorMsg: 'Decrypt result is null'
      }
    }
    
    const decryptedValue: string = decrypted!
    console.log('[uni-crypto iOS] aesGcmDecrypt:', decryptedValue)
    
    return {
      decrypted: decryptedValue,
      errorMsg: ''
    }
  } catch (e) {
    console.error('[uni-crypto iOS] aesGcmDecrypt 错误:', e)
    return {
      decrypted: '',
      errorMsg: `Error: ${e}`
    }
  }
}

