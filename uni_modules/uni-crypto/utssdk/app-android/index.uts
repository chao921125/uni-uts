// ==================== SM2 ====================

export function sm2KeyGenerate(): string {
  try {
    const keyPairJson = getBridge().sm2KeyGenerate()
    
    if (keyPairJson == null) {
      console.error('[uni-crypto Android] sm2KeyGenerate: null')
      return ''
    }
    
    const keyPair: string = keyPairJson!
    console.log('[uni-crypto Android] sm2KeyGenerate:', keyPair.substring(0, 80))
    
    return keyPair
  } catch (e) {
    console.error('[uni-crypto Android] sm2KeyGenerate 错误:', e)
    return ''
  }
}

export function sm2Encrypt(publicKey: string, plaintext: string): string {
  try {
    const encrypted = getBridge().sm2EncryptWithPublicKey(publicKey, plaintext)
    
    if (encrypted == null) {
      console.error('[uni-crypto Android] sm2Encrypt: null')
      return ''
    }
    
    const encryptedValue: string = encrypted!
    console.log('[uni-crypto Android] sm2Encrypt:', encryptedValue.substring(0, 80))
    
    return encryptedValue
  } catch (e) {
    console.error('[uni-crypto Android] sm2Encrypt 错误:', e)
    return ''
  }
}

export function sm2Decrypt(privateKey: string, ciphertext: string): string {
  try {
    const decrypted = getBridge().sm2DecryptWithPrivateKey(privateKey, ciphertext)
    
    if (decrypted == null) {
      console.error('[uni-crypto Android] sm2Decrypt: null')
      return ''
    }
    
    const decryptedValue: string = decrypted!
    console.log('[uni-crypto Android] sm2Decrypt:', decryptedValue)
    
    return decryptedValue
  } catch (e) {
    console.error('[uni-crypto Android] sm2Decrypt 错误:', e)
    return ''
  }
}

export function sm2Sign(privateKey: string, message: string): string {
  try {
    const signature = getBridge().sm2SignWithPrivateKey(privateKey, message)
    
    if (signature == null) {
      console.error('[uni-crypto Android] sm2Sign: null')
      return ''
    }
    
    const signatureValue: string = signature!
    console.log('[uni-crypto Android] sm2Sign:', signatureValue.substring(0, 80))
    
    return signatureValue
  } catch (e) {
    console.error('[uni-crypto Android] sm2Sign 错误:', e)
    return ''
  }
}

export function sm2Verify(publicKey: string, message: string, signature: string): boolean {
  try {
    const verifyResult = getBridge().sm2VerifyWithPublicKey(publicKey, message, signature)
    
    if (verifyResult == null) {
      console.error('[uni-crypto Android] sm2Verify: null')
      return false
    }
    
    const result: string = verifyResult!
    console.log('[uni-crypto Android] sm2Verify:', result)

    return result == '1'
  } catch (e) {
    console.error('[uni-crypto Android] sm2Verify 错误:', e)
    return false
  }
}

