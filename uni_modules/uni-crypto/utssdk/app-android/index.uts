export function aesGcmEncrypt(key: string, iv: string, aad: string, data: string): AESGcmEncryptResult {
  try {
    let aadValue: string | null = null
    if (aad.length > 0) {
      aadValue = aad
    }
    const encrypted = getBridge().aesGcmEncryptWithKey(key, iv, aadValue, data)
    
    if (encrypted == null) {
      return {
        encrypted: '',
        errorMsg: 'Encrypt result is null'
      }
    }
    
    const encryptedValue: string = encrypted!
    console.log('[uni-crypto Android] aesGcmEncrypt:', encryptedValue)
    
    return {
      encrypted: encryptedValue,
      errorMsg: ''
    }
  } catch (e) {
    console.error('[uni-crypto Android] aesGcmEncrypt 错误:', e)
    return {
      encrypted: '',
      errorMsg: `Error: ${e.toString()}`
    }
  }
}

export function aesGcmDecrypt(key: string, iv: string, aad: string, encrypted: string): AESGcmDecryptResult {
  try {
    let aadValue: string | null = null
    if (aad.length > 0) {
      aadValue = aad
    }
    const decrypted = getBridge().aesGcmDecryptWithKey(key, iv, aadValue, encrypted)
    
    if (decrypted == null) {
      return {
        decrypted: '',
        errorMsg: 'Decrypt result is null'
      }
    }
    
    const decryptedValue: string = decrypted!
    console.log('[uni-crypto Android] aesGcmDecrypt:', decryptedValue)
    
    return {
      decrypted: decryptedValue,
      errorMsg: ''
    }
  } catch (e) {
    console.error('[uni-crypto Android] aesGcmDecrypt 错误:', e)
    return {
      decrypted: '',
      errorMsg: `Error: ${e.toString()}`
    }
  }
}
