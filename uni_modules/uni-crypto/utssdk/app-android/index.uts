/**
 * app-android/index.uts
 * uni-crypto 插件 Android 平台实现
 * 通过 Kotlin JNI 桥接类调用 C 语言编译的 so 库
 * 由于 utssdk 的 app 端不支持返回对象，无法直接实现`crypto.sm4.encrypt(xxx)`，所以这里仅返回函数，然后在 uni_modules/uni-crypto/index.uts 中包装成 crypto 对象，与 web 保持一致。
 */

// 导入接口类型定义
import { 
  GetVersionResult, 
  SM3HashResult,
  SM4EncryptResult,
  SM4DecryptResult,
  SM4CbcEncryptResult,
  SM4CbcDecryptResult,
  SM3HmacResult,
  SHA256HashResult,
  MD5HashResult,
  AESEncryptResult,
  AESDecryptResult,
  AESGcmEncryptResult,
  AESGcmDecryptResult,
  EchoResult
} from '../interface.uts'

// 从 Kotlin 桥接类导入
import { GmSSLBridge } from 'com.dcloud.gmssl'

// 桥接类实例（单例模式）
let bridge: GmSSLBridge | null = null

/**
 * 获取桥接类实例
 * 使用懒加载模式，只在第一次调用时创建实例
 * @returns GmSSLBridge 实例
 */
function getBridge(): GmSSLBridge {
  if (bridge == null) {
    bridge = new GmSSLBridge()
  }
  return bridge!
}

/**
 * SM3 哈希计算
 * 调用 Kotlin 桥接方法 sm3HashWithData，最终调用 C 函数 sm3Hash(data)
 * @param data 要哈希的数据（hex 字符串）
 * @returns 返回哈希结果对象
 */
export function sm3Hash(data: string): SM3HashResult {
  try {
    const hash = getBridge().sm3HashWithData(data)

    if (hash == null) {
      console.log('[uni-crypto Android] sm3Hash: null')
      return {
        result: '',
        errorMsg: 'Hash result is null'
      }
    }

    const hashValue: string = hash!
    console.log('[uni-crypto Android] sm3Hash:', hashValue)

    if (hashValue.length == 0) {
      return {
        result: '',
        errorMsg: 'Hash result is empty'
      }
    }

    return {
      result: hashValue,
      errorMsg: ''
    }
  } catch (e) {
    console.error('[uni-crypto Android] sm3Hash 错误:', e)
    return {
      result: '',
      errorMsg: `Error: ${e.toString()}`
    }
  }
}

/**
 * SM4 加密
 * 调用 Kotlin 桥接方法 sm4EncryptWithKey，最终调用 C 函数 sm4Encrypt(key, data)
 * @param key 加密密钥（hex 字符串，32字符=16字节）
 * @param data 待加密数据（hex 字符串，32字符=16字节）
 * @returns 返回加密结果对象
 */
export function sm4Encrypt(key: string, data: string): SM4EncryptResult {
  try {
    const encrypted = getBridge().sm4EncryptWithKey(key, data)

    if (encrypted == null) {
      console.log('[uni-crypto Android] sm4Encrypt: null')
      return {
        encrypted: '',
        errorMsg: 'Encrypt result is null'
      }
    }

    const encryptedValue: string = encrypted!
    console.log('[uni-crypto Android] sm4Encrypt:', encryptedValue)

    if (encryptedValue.length == 0) {
      return {
        encrypted: '',
        errorMsg: 'Encrypt result is empty'
      }
    }

    return {
      encrypted: encryptedValue,
      errorMsg: ''
    }
  } catch (e) {
    console.error('[uni-crypto Android] sm4Encrypt 错误:', e)
    return {
      encrypted: '',
      errorMsg: `Error: ${e.toString()}`
    }
  }
}

/**
 * SM4 解密
 * 调用 Kotlin 桥接方法 sm4DecryptWithKey，最终调用 C 函数 sm4Decrypt(key, encrypted)
 * @param key 解密密钥（hex 字符串，32字符=16字节）
 * @param encrypted 加密数据（hex 字符串，32字符=16字节）
 * @returns 返回解密结果对象
 */
export function sm4Decrypt(key: string, encrypted: string): SM4DecryptResult {
  try {
    const decrypted = getBridge().sm4DecryptWithKey(key, encrypted)

    if (decrypted == null) {
      console.log('[uni-crypto Android] sm4Decrypt: null')
      return {
        decrypted: '',
        errorMsg: 'Decrypt result is null'
      }
    }

    const decryptedValue: string = decrypted!
    console.log('[uni-crypto Android] sm4Decrypt:', decryptedValue)

    if (decryptedValue.length == 0) {
      return {
        decrypted: '',
        errorMsg: 'Decrypt result is empty'
      }
    }

    return {
      decrypted: decryptedValue,
      errorMsg: ''
    }
  } catch (e) {
    console.error('[uni-crypto Android] sm4Decrypt 错误:', e)
    return {
      decrypted: '',
      errorMsg: `Error: ${e.toString()}`
    }
  }
}

